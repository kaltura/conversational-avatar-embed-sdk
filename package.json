{
  "name": "conversational-avatar-embed-sdk",
  "version": "2.0.0",
  "description": "Kaltura Avatar SDK — Embed AI avatar conversations in any website (Socket + Iframe)",
  "main": "sdk-iframe/kaltura-avatar-sdk.js",
  "scripts": {
    "test": "npm run test:iframe && npm run test:socket",
    "test:iframe": "node examples/hr_avatar/test-e2e.js && node examples/code_interview/test-e2e.js",
    "test:socket": "cd sdk-socket && npm test",
    "test:socket:live": "cd sdk-socket && npm run test:live",
    "test:install": "npx playwright install chromium",
    "demo": "python3 -m http.server 8080"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaltura/conversational-avatar-embed-sdk.git"
  },
  "keywords": [
    "kaltura",
    "avatar",
    "ai",
    "sdk",
    "conversational-ai",
    "webrtc",
    "embed",
    "video-chat",
    "real-time",
    "genui",
    "interactive",
    "iframe",
    "socket.io"
  ],
  "author": "Kaltura",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kaltura/conversational-avatar-embed-sdk/issues"
  },
  "homepage": "https://github.com/kaltura/conversational-avatar-embed-sdk#readme",
  "devDependencies": {
    "playwright": "^1.58.2"
  }
}
